# Personal app — only two keys, both optional (the app degrades without them).

# JSearch (RapidAPI) — real job listings. Free tier: 100 requests/month.
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# Groq — resume parsing, match scoring, cover letters. Free tier.
# https://console.groq.com/keys
GROQ_API_KEY=

# SMTP Email Configuration (Optional - for sending cold emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM="Your Name" <your-email@gmail.com>
